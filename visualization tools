# io.py
# Responsible for loading simulation snapshots from disk.
# All visualization files must use this module to access data.


FUNCTION load_snapshot(file_path):

    # Read file from disk (JSON, pickle, etc.)
    data = read_file(file_path)

    snapshot = {
        "time": data["time"],
        "masses": data["masses"],
        "radii": data["radii"],
        "stokes": data["stokes"],
        "stopping_times": data["stopping_times"],
        "collision_log": data["collision_log"]   # optional
    }

    RETURN snapshot


FUNCTION load_all_snapshots(folder_path):

    file_list = list files in folder_path
    sort file_list by time

    snapshots = empty list

    FOR each file in file_list:
        snapshot = load_snapshot(file)
        append snapshot to snapshots

    RETURN snapshots


# viz_distributions.py
# Responsible for mass distribution plots.


FUNCTION plot_mass_distribution(snapshot, bins):

    masses = snapshot["masses"]
    time = snapshot["time"]

    compute histogram of masses using bins

    create plot
    set x-axis label = "Mass"
    set y-axis label = "Number of Particles"
    set title = "Mass Distribution at time = time"

    RETURN figure


FUNCTION compare_mass_distributions(snapshot_list, selected_indices, bins):

    create plot

    FOR each index in selected_indices:

        snapshot = snapshot_list[index]
        masses = snapshot["masses"]
        time = snapshot["time"]

        compute histogram of masses using bins

        overlay histogram curve
        label curve with time

    set x-axis label = "Mass"
    set y-axis label = "Number of Particles"
    set title = "Mass Distribution Comparison"
    add legend

    RETURN figure



# viz_evolution.py
# Responsible for time evolution plots.


FUNCTION plot_stokes_evolution(snapshot_list):

    times = empty list
    mean_stokes = empty list

    FOR each snapshot in snapshot_list:

        time = snapshot["time"]
        stokes_values = snapshot["stokes"]

        compute mean of stokes_values

        append time to times
        append mean to mean_stokes

    create line plot of mean_stokes vs times

    set x-axis label = "Time"
    set y-axis label = "Mean Stokes Number"
    set title = "Stokes Number Evolution"

    RETURN figure


FUNCTION plot_stoppingtime_evolution(snapshot_list):

    times = empty list
    mean_stopping = empty list

    FOR each snapshot in snapshot_list:

        time = snapshot["time"]
        stopping_values = snapshot["stopping_times"]

        compute mean of stopping_values

        append time
        append mean

    create line plot of mean_stopping vs times

    set x-axis label = "Time"
    set y-axis label = "Mean Stopping Time"
    set title = "Stopping Time Evolution"

    RETURN figure




# viz_collision_stats.py
# Responsible for collision regime classification and plotting.


FUNCTION classify_collision(collision_record):

    v_brown = collision_record["v_brown"]
    v_turb = collision_record["v_turb"]
    v_drift = collision_record["v_drift"]

    IF v_brown >= v_turb AND v_brown >= v_drift:
        RETURN "brownian"

    ELSE IF v_turb >= v_brown AND v_turb >= v_drift:
        RETURN "turbulence"

    ELSE:
        RETURN "drift"


