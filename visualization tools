# viz_trajectories.py
# Responsible for growth trajectory plots.


FUNCTION track_largest_particle(snapshot_list):

    times = empty list
    largest_masses = empty list

    FOR each snapshot:

        time = snapshot["time"]
        masses = snapshot["masses"]

        largest = maximum value in masses

        append time
        append largest

    RETURN times, largest_masses


FUNCTION track_median_mass(snapshot_list):

    times = empty list
    median_masses = empty list

    FOR each snapshot:

        time = snapshot["time"]
        masses = snapshot["masses"]

        median = median value of masses

        append time
        append median

    RETURN times, median_masses


FUNCTION plot_trajectory(times, values, label):

    create line plot of values vs times
    set x-axis label = "Time"
    set y-axis label = label
    set title = "Growth Trajectory"
    add legend

    RETURN figure


# run_visualizations.py
# Central script to run all visualization tools.


IMPORT load_all_snapshots
IMPORT all plotting functions


FUNCTION main():

    snapshots = load_all_snapshots("output/snapshots")

    # ---- Plot 1: Mass distribution comparison ----
    total_snapshots = length of snapshots

    selected_indices = evenly spaced 5 indices from 0 to total_snapshots - 1

    fig1 = compare_mass_distributions(snapshots, selected_indices, bins=...)

    save fig1 to "output/figures/mass_comparison.png"


    # ---- Plot 2A: Stokes evolution ----
    fig2 = plot_stokes_evolution(snapshots)
    save fig2 to "output/figures/stokes_evolution.png"


    # ---- Plot 2B: Stopping time evolution ----
    fig3 = plot_stoppingtime_evolution(snapshots)
    save fig3 to "output/figures/stopping_time_evolution.png"


    # ---- Plot 3: Collision regime fractions ----
    fig4 = plot_collision_regime_fractions(snapshots, time_bins=...)
    save fig4 to "output/figures/collision_regimes.png"


    # ---- Plot 4: Growth trajectories ----
    times_l, largest = track_largest_particle(snapshots)
    times_m, median = track_median_mass(snapshots)

    fig5 = plot_trajectory(times_l, largest, "Largest Mass")
    overlay median curve

    save fig5 to "output/figures/growth_trajectory.png"


