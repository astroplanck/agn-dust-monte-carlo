FUNCTION relative_velocity(particle_i, particle_j, disk_state, params):

    m_i = particle_i.mass
    m_j = particle_j.mass

    St_i = particle_i.St
    St_j = particle_j.St

    T  = disk_state.T
    cs = disk_state.cs

    # Brownian contribution
    v_brownian = brownian_velocity(m_i, m_j, T)

    # Turbulent contribution
    v_turbulence = turbulent_velocity(St_i, St_j, cs, params.alpha)

    # Drift contribution
    v_drift_i = radial_drift_velocity(St_i, disk_state)
    v_drift_j = radial_drift_velocity(St_j, disk_state)
    v_drift = absolute_value(v_drift_i - v_drift_j)

    v_rel = sqrt(
        v_brownian^2 +
        v_turbulence^2 +
        v_drift^2
    )

    RETURN v_rel

FUNCTION compute_kernel_factors(particles, disk_state, params):

    f_array = empty array
    g_array = empty array

    FOR each particle i in particles:

        a_i = particle_i.radius
        St_i = particle_i.St

        # Example factor based on geometric size
        f_i = a_i^2

        # Example factor based on particle dynamical state
        g_i = characteristic_velocity(St_i, disk_state, params)

        append f_i to f_array
        append g_i to g_array

    RETURN f_array, g_array




