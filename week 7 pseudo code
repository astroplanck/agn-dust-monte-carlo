FUNCTION sample_dt(Lambda):

    IF Lambda <= 0:
        RAISE error

    u = random number uniformly sampled from (0,1)

    dt = -log(u) / Lambda

    RETURN dt

FUNCTION select_particle_i(lambda_array):

    Lambda = SUM of lambda_array

    IF Lambda <= 0:
        RAISE error

    probs_i = lambda_array / Lambda

    i = RANDOM_CHOICE(indices, probability = probs_i)

    RETURN i

FUNCTION select_particle_j(g_array, i):

    sum_g = SUM of g_array

    IF sum_g <= 0:
        RAISE error

    probs_j = g_array / sum_g

    REPEAT:
        j = RANDOM_CHOICE(indices, probability = probs_j)
    UNTIL j != i

    RETURN j




