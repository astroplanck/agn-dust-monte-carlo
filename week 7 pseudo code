FUNCTION compute_lambda_i(f_array, g_array):

    sum_g = SUM of all values in g_array

    lambda_array = empty array

    FOR each index i:

        lambda_i = f_array[i] * sum_g

        append lambda_i to lambda_array

    RETURN lambda_array

FUNCTION compute_total_rate(lambda_array):

    Lambda = SUM of all values in lambda_array

    RETURN Lambda




